# Copy to .env and adjust. Loaded by api + worker.
# MySQL. NOTE: special chars in the password must be URL-encoded (# -> %23).
DATABASE_URL="mysql://root:D0th%23123@localhost:3306/crawller"
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
JWT_SECRET="change-me-to-a-long-random-string"
WEB_APP_URL="http://localhost:5173"

# Email delivery. Without RESEND_API_KEY, auth emails are logged by the API in dev.
EMAIL_FROM="Webtummy <no-reply@example.com>"
RESEND_API_KEY=""

# Crawler defaults (overridable per crawl)
CRAWL_DEFAULT_MAX_PAGES=500
CRAWL_DEFAULT_MAX_DEPTH=10
CRAWL_FETCH_CONCURRENCY=5
CRAWL_REQUEST_TIMEOUT_MS=15000
CRAWL_MAX_REDIRECTS=5
CRAWL_USER_AGENT="DotH-SEO-Crawler/0.1 (+https://dothdigital.example/bot)"

# External APIs
PAGESPEED_API_KEY=""
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
DATAFORSEO_AUTH_BASE64=""

# S3 / MinIO (Phase 2 — report + HTML storage)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="crawler"
S3_SECRET_KEY="crawler123"
S3_BUCKET="crawler"
